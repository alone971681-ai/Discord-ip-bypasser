# ── Required ──────────────────────────────────────────────────────────────────
# Your Discord account token (NOT a bot token — your personal user token).
# Get it: Discord → F12 → Network → any request → Authorization header
TOKEN=your_discord_account_token_here

# Your Discord user ID (right-click your username → Copy User ID)
OWNER_ID=your_discord_user_id_here

# ── Strongly recommended ───────────────────────────────────────────────────────
# Residential or ISP proxy — the main line of defence against IP bans.
# Format: http://user:pass@host:port  OR  socks5://user:pass@host:port
#
# Recommended (residential IPs only — datacenter/VPN IPs will still get flagged):
#   IPRoyal ISP sticky:  https://iproyal.com  (~$2.40/IP/month)
#   Brightdata:          https://brightdata.com (~$8.40/GB)
#   Oxylabs:             https://oxylabs.io
#
# For phone verification numbers (SMS, NOT VoIP):
#   https://sms-activate.org  or  https://5sim.net  (~$0.20-0.50/number)
PROXY_URL=http://user:pass@proxy-host:port

# ── Optional ───────────────────────────────────────────────────────────────────
# Random string used to sign Flask session cookies.
SESSION_SECRET=change_this_to_a_random_string
